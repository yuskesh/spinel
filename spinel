#!/bin/sh
# Spinel AOT Compiler - Ruby to native binary
#
# Drives the C compiler (build/spinelc): a single binary that parses,
# infers types, and emits C in one process. This script then invokes cc
# to link the generated C against libspinel_rt.a. (The legacy Ruby
# backend lives in ./spinel-legacy, kept only as a regression oracle.)
#
# Usage:
#   spinel app.rb                  - compiles to ./app
#   spinel app.rb -o myapp         - compiles to ./myapp
#   spinel app.rb -c               - generate C only (app.c)
#   spinel app.rb -c -o app.c      - generate C to a specific file
#   spinel app.rb -S               - print C to stdout
#   spinel -e 'puts 42'            - compile inline source (default name: a)
#   spinel -E app.rb a b c         - compile to /tmp, run, ARGV=[a, b, c]
#
# Options:
#   -o FILE    Output file (binary, or C when combined with -c)
#   -c         Generate C source only, don't compile
#   --emit-rbs Dump inferred type signatures as RBS (-> app.rbs), no binary
#   --emit-symbol-map  Dump emitted-symbol -> Ruby-name map as JSON, no binary
#   -S         Print generated C to stdout
#   -E         Run the compiled binary instead of saving it; the
#              first .rb file ends spinel-flag parsing, and the rest
#              of the command line becomes the binary's ARGV.
#   -O LEVEL   Optimization level for cc (default: 2)
#   -g         Add debug info (-g) + #line, leaving -O as-is
#   --debug    Debug build: #line directives + -g -O0, so gdb/lldb step
#              through the original .rb source
#   --line-map     Emit #line directives (on by default)
#   --no-line-map  Suppress #line directives (compile errors map to the
#              generated C, not the Ruby source)
#   --cc=CMD   C compiler command (default: cc)
#   -e STR     Inline Ruby source (repeatable; multiple -e join with \n)
#   --int-overflow=MODE  Int +/-/* overflow handling (default: raise)
#              raise | wrap | promote

DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")")" && pwd)"

# Locate spinelc: a dev tree builds it at build/spinelc; an installed tree
# drops it next to this script.
SPINELC="$DIR/build/spinelc"
[ ! -x "$SPINELC" ] && [ -x "$DIR/spinelc" ] && SPINELC="$DIR/spinelc"
case "$(uname -s 2>/dev/null)" in
  MINGW*|MSYS*|CYGWIN*)
    [ ! -x "$SPINELC" ] && [ -x "$SPINELC.exe" ] && SPINELC="$SPINELC.exe"
    ;;
esac

SOURCE=""
OUTPUT=""
C_ONLY=0
STDOUT_MODE=0
RUN_MODE=0
EMIT_RBS=0
EMIT_SYMBOL_MAP=0
OPT_LEVEL="2"
CC_CMD="cc"
EXTRA_FLAGS=""
C_TMP=""
C_TMP_DIR=""
RUN_TMP_DIR=""
EVAL_SCRIPT=""
EVAL_USED=0
EVAL_TMP=""
INT_OVERFLOW="raise"
DEBUG=0
# #line directives are on by default: they cost nothing at runtime (the binary
# is identical modulo line attribution) and let the C toolchain report a
# compile error on the generated C against the Ruby source line. Opt out with
# --no-line-map.
LINE_MAP=1

# Parse spinel-side flags. In `-E` (run) mode, the first positional `.rb`
# arg marks the boundary between spinel flags and the script's ARGV:
# everything after that point is passed straight to the compiled binary.
while [ $# -gt 0 ]; do
  case "$1" in
    --source=*) SOURCE="${1#--source=}"; shift ;;
    --output=*) OUTPUT="${1#--output=}"; shift ;;
    --cc=*)     CC_CMD="${1#--cc=}"; shift ;;
    --int-overflow=*) INT_OVERFLOW="${1#--int-overflow=}"; shift ;;
    --int-overflow)   shift; INT_OVERFLOW="$1"; shift ;;
    --)         # `--` ends spinel-flag parsing.
                shift
                if [ "$RUN_MODE" -eq 1 ]; then
                  if [ -z "$SOURCE" ] && [ $# -gt 0 ]; then
                    SOURCE="$1"
                    shift
                  fi
                  break
                fi
                if [ -z "$SOURCE" ] && [ $# -gt 0 ]; then
                  SOURCE="$1"
                  shift
                fi
                break
                ;;
    -o)         shift; OUTPUT="$1"; shift ;;
    -O)         shift; OPT_LEVEL="$1"; shift ;;
    --debug)    # Debug build: native-debugger stepping through the .rb. Emits
                # #line directives, forces -O0, and adds -g.
                DEBUG=1; OPT_LEVEL="0"; EXTRA_FLAGS="$EXTRA_FLAGS -g"; shift ;;
    -g)         # Debug info + #line, but leave -O as-is.
                DEBUG=1; EXTRA_FLAGS="$EXTRA_FLAGS -g"; shift ;;
    --line-map) # Emit #line directives (on by default; kept for explicitness).
                LINE_MAP=1; shift ;;
    --no-line-map) # Suppress #line directives (compile errors report against
                # the generated C instead of the Ruby source).
                LINE_MAP=0; shift ;;
    -e)         shift
                if [ "$EVAL_USED" -eq 0 ]; then
                  EVAL_SCRIPT="$1"
                else
                  EVAL_SCRIPT="$EVAL_SCRIPT
$1"
                fi
                EVAL_USED=1
                shift ;;
    -c)         C_ONLY=1; shift ;;
    --emit-rbs) # Dump inferred type signatures as RBS (-> app.rbs).
                # Analyze-only; writes no binary.
                EMIT_RBS=1; shift ;;
    --emit-symbol-map) # Dump emitted-C-symbol -> Ruby-name map as JSON
                # (-> app.symbols.json). Analyze-only; writes no binary.
                EMIT_SYMBOL_MAP=1; shift ;;
    -S)         STDOUT_MODE=1; shift ;;
    -E)         RUN_MODE=1; shift ;;
    *.rb)
                if [ -z "$SOURCE" ]; then
                  SOURCE="$1"
                  shift
                  [ "$RUN_MODE" -eq 1 ] && break
                else
                  shift
                fi
                ;;
    *)
                if [ "$RUN_MODE" -eq 1 ]; then
                  break
                fi
                shift
                ;;
  esac
done

# Mode-conflict checks: `-E` short-circuits to "run the produced binary"
# so output-saving flags (`-o`, `-c`, `-S`) don't make sense alongside it.
if [ "$RUN_MODE" -eq 1 ]; then
  if [ -n "$OUTPUT" ]; then
    echo "spinel: -E (run) cannot be combined with -o" >&2
    exit 2
  fi
  if [ "$C_ONLY" -eq 1 ]; then
    echo "spinel: -E (run) cannot be combined with -c" >&2
    exit 2
  fi
  if [ "$STDOUT_MODE" -eq 1 ]; then
    echo "spinel: -E (run) cannot be combined with -S" >&2
    exit 2
  fi
fi

# `-e` mode: write the accumulated inline script to a temp file and treat
# it as the source. Default output name is `a` since the inline form has
# no .rb basename to derive from.
if [ "$EVAL_USED" -eq 1 ]; then
  EVAL_BASE="$(mktemp -u /tmp/spinel_eval.XXXXXX)"
  EVAL_TMP="${EVAL_BASE}.rb"
  printf '%s\n' "$EVAL_SCRIPT" > "$EVAL_TMP"
  SOURCE="$EVAL_TMP"
fi

if [ -z "$SOURCE" ]; then
  echo "Spinel AOT Compiler" >&2
  echo "" >&2
  echo "Usage: spinel app.rb              - compile to ./app" >&2
  echo "       spinel app.rb -o myapp     - compile to ./myapp" >&2
  echo "       spinel app.rb -c           - generate app.c only" >&2
  echo "       spinel app.rb -S           - print C to stdout" >&2
  echo "       spinel -e 'puts 42'        - compile inline source" >&2
  echo "       spinel -E app.rb a b c     - compile + run with ARGV=[a, b, c]" >&2
  echo "" >&2
  echo "Options:" >&2
  echo "  -o FILE     Output file" >&2
  echo "  -c          C source only (don't compile)" >&2
  echo "  --emit-rbs  Dump inferred type signatures as RBS (-> app.rbs), no binary" >&2
  echo "  --emit-symbol-map  Dump emitted-symbol -> Ruby-name map as JSON, no binary" >&2
  echo "  -S          Print C to stdout" >&2
  echo "  -E          Run the compiled binary; leftover args become its ARGV" >&2
  echo "  -O LEVEL    Optimization level (default: 2)" >&2
  echo "  -g          Add debug info (-g) + #line, leaving -O as-is" >&2
  echo "  --debug     Debug build: step through the .rb in gdb/lldb (#line, -g -O0)" >&2
  echo "  --no-line-map  Suppress #line directives (compile errors report" >&2
  echo "              against generated C, not the Ruby source)" >&2
  echo "  --cc=CMD    C compiler (default: cc)" >&2
  echo "  -e STR      Inline Ruby source (repeatable; joined with newlines)" >&2
  echo "  --int-overflow=MODE  Int +/-/* overflow handling (default: raise)" >&2
  exit 1
fi

if [ ! -f "$SOURCE" ]; then
  echo "spinel: $SOURCE: No such file" >&2
  exit 1
fi

if [ ! -x "$SPINELC" ]; then
  echo "spinel: compiler binary not found at $SPINELC; run 'make' first" >&2
  exit 1
fi

if [ "$EVAL_USED" -eq 1 ]; then
  BASENAME="a"
else
  BASENAME="$(basename "$SOURCE" .rb)"
fi
trap 'rm -f "$EVAL_TMP"; [ -n "$C_TMP_DIR" ] && rm -rf "$C_TMP_DIR"; [ -n "$RUN_TMP_DIR" ] && rm -rf "$RUN_TMP_DIR"' EXIT

# Source mapping: spinelc's parser stamps per-node source lines and codegen
# emits `#line N "file"` when SPINEL_DEBUG / SPINEL_LINE_MAP is set, so a C
# compile error is reported against the original Ruby line. --debug / -g imply
# the fuller SPINEL_DEBUG path (plus -g, set above); plain --line-map keeps the
# optimized build and just adds #line.
if [ "$DEBUG" -eq 1 ]; then
  export SPINEL_DEBUG=1
  # Native Exception#backtrace on Linux: glibc's backtrace_symbols only names
  # frames whose symbols are in the dynamic symbol table; -rdynamic exports
  # them. ELF-only -- skip on macOS (Mach-O resolves already) and MinGW/Cygwin.
  case "$(uname -s 2>/dev/null)" in
    Darwin|MINGW*|MSYS*|CYGWIN*) ;;
    *) EXTRA_FLAGS="$EXTRA_FLAGS -rdynamic" ;;
  esac
elif [ "$LINE_MAP" -eq 1 ]; then
  export SPINEL_LINE_MAP=1
fi

# --emit-rbs: analyze-only. spinelc writes the .rbs itself (driven by
# SPINEL_EMIT_RBS) and emits an empty translation unit. No source positions
# needed, so the parser stays in its normal (fast) mode.
if [ "$EMIT_RBS" -eq 1 ]; then
  RBS_OUT="${OUTPUT:-$BASENAME.rbs}"
  export SPINEL_EMIT_RBS="$RBS_OUT"
  if ! "$SPINELC" "$SOURCE" >/dev/null; then
    echo "spinel: emit-rbs failed" >&2
    exit 1
  fi
  echo "Wrote $RBS_OUT" >&2
  exit 0
fi

# --emit-symbol-map: analyze-only. spinelc writes the JSON itself (driven by
# SPINEL_EMIT_SYMBOL_MAP) and emits an empty translation unit; SPINEL_DEBUG
# makes the parser stamp node positions so each symbol carries its file/line.
if [ "$EMIT_SYMBOL_MAP" -eq 1 ]; then
  SYM_OUT="${OUTPUT:-$BASENAME.symbols.json}"
  export SPINEL_DEBUG=1
  export SPINEL_EMIT_SYMBOL_MAP="$SYM_OUT"
  if ! "$SPINELC" "$SOURCE" >/dev/null; then
    echo "spinel: emit-symbol-map failed" >&2
    exit 1
  fi
  echo "Wrote $SYM_OUT" >&2
  exit 0
fi

# Step 1: Compile (parse + analyze + codegen) — spinelc emits C.
if [ "$STDOUT_MODE" -eq 1 ]; then
  "$SPINELC" "$SOURCE"
  exit $?
fi

if [ "$C_ONLY" -eq 1 ]; then
  C_FILE="${OUTPUT:-$BASENAME.c}"
else
  C_TMP_DIR="$(mktemp -d /tmp/spinel_out.XXXXXX)" || { echo "spinel: mktemp -d failed" >&2; exit 1; }
  C_TMP="$C_TMP_DIR/out.c"
  C_FILE="$C_TMP"
fi

"$SPINELC" "$SOURCE" -o "$C_FILE"
if [ $? -ne 0 ]; then
  echo "spinel: compile failed" >&2
  exit 1
fi

if [ "$C_ONLY" -eq 1 ]; then
  echo "Wrote $C_FILE" >&2
  exit 0
fi

# Step 2: Compile C -> binary.
# In -E (run) mode the binary is short-lived: drop it into a fresh temp
# dir so the cwd stays clean and the trap reaps it on exit.
if [ "$RUN_MODE" -eq 1 ]; then
  RUN_TMP_DIR="$(mktemp -d /tmp/spinel_run.XXXXXX)" || { echo "spinel: mktemp -d failed" >&2; exit 1; }
  BIN_FILE="$RUN_TMP_DIR/$BASENAME"
else
  BIN_FILE="${OUTPUT:-$BASENAME}"
fi

# Runtime library (bigint + regexp + …).
SP_RT_LIB="$DIR/lib/libspinel_rt.a"
INCLUDE_FLAGS="-I$DIR/lib -I$DIR/lib/regexp"
if [ -f "$SP_RT_LIB" ]; then
  EXTRA_FLAGS="$EXTRA_FLAGS $SP_RT_LIB"
fi

# Scrape FFI link/cflag markers emitted by the codegen. Each line looks
# like "/* SPINEL_LINK: -lraylib */" or "/* SPINEL_CFLAGS: -I/foo */".
FFI_LINKS=$(sed -n 's|^/\* SPINEL_LINK: \(.*\) \*/$|\1|p' "$C_FILE" | tr '\n' ' ')
FFI_CFLAGS=$(sed -n 's|^/\* SPINEL_CFLAGS: \(.*\) \*/$|\1|p' "$C_FILE" | tr '\n' ' ')

if [ "$(uname -s)" = "Darwin" ]; then
  GC_FLAG="-Wl,-dead_strip"
else
  GC_FLAG="-Wl,--gc-sections"
fi

# MinGW's default 1MB stack overflows on nontrivial programs; reserve 64MB.
case "$(uname -s 2>/dev/null)" in
  MINGW*|MSYS*|CYGWIN*) EXTRA_FLAGS="$EXTRA_FLAGS -Wl,--stack,67108864" ;;
esac

case "$INT_OVERFLOW" in
  raise)   EXTRA_FLAGS="$EXTRA_FLAGS -DSP_INT_OVERFLOW_MODE_RAISE" ;;
  wrap)    EXTRA_FLAGS="$EXTRA_FLAGS -DSP_INT_OVERFLOW_MODE_WRAP" ;;
  promote) EXTRA_FLAGS="$EXTRA_FLAGS -DSP_INT_OVERFLOW_MODE_PROMOTE" ;;
  *) echo "spinel: --int-overflow expects raise|wrap|promote, got '$INT_OVERFLOW'" >&2; exit 2 ;;
esac
$CC_CMD -O${OPT_LEVEL} -Wno-all -ffunction-sections -fdata-sections $INCLUDE_FLAGS $FFI_CFLAGS "$C_FILE" -lm $EXTRA_FLAGS $FFI_LINKS $GC_FLAG -o "$BIN_FILE"
if [ $? -ne 0 ]; then
  echo "spinel: C compilation failed" >&2
  exit 1
fi

if [ "$RUN_MODE" -eq 1 ]; then
  # Hand off to the freshly compiled binary, forwarding the leftover
  # positionals as its ARGV. Run as a subprocess (not exec) so the EXIT
  # trap reaps RUN_TMP_DIR after the child returns.
  "$BIN_FILE" "$@"
  exit $?
fi

echo "$SOURCE -> $BIN_FILE" >&2
