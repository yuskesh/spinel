#!/bin/sh
# Spinel AOT Compiler - Ruby to native binary
#
# Usage:
#   spinel app.rb                  - compiles to ./app
#   spinel app.rb -o myapp         - compiles to ./myapp
#   spinel app.rb -c               - generate C only (app.c)
#   spinel app.rb -c -o app.c     - generate C to specific file
#   spinel app.rb -S               - print C to stdout
#   spinel -e 'puts 42'            - compile inline source (default name: a)
#
# Options:
#   -o FILE    Output file (binary or C depending on -c)
#   -c         Generate C source only, don't compile
#   -S         Print generated C to stdout
#   -O LEVEL   Optimization level for cc (default: 2)
#   --cc=CMD   C compiler command (default: cc)
#   -e STR     Inline Ruby source (repeatable; multiple -e join with \n)

DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")")" && pwd)"
PARSE_BIN="$DIR/spinel_parse"
ANALYZE_RB="$DIR/spinel_analyze.rb"
ANALYZE_BIN="$DIR/spinel_analyze"
CODEGEN_RB="$DIR/spinel_codegen.rb"
CODEGEN_BIN="$DIR/spinel_codegen"

# On Windows (MSYS2 / Cygwin / MinGW) the compiled binaries carry a .exe
# suffix; fall back to that when the unsuffixed path is absent.
case "$(uname -s 2>/dev/null)" in
  MINGW*|MSYS*|CYGWIN*)
    [ ! -x "$PARSE_BIN"   ] && [ -x "$PARSE_BIN.exe"   ] && PARSE_BIN="$PARSE_BIN.exe"
    [ ! -x "$ANALYZE_BIN" ] && [ -x "$ANALYZE_BIN.exe" ] && ANALYZE_BIN="$ANALYZE_BIN.exe"
    [ ! -x "$CODEGEN_BIN" ] && [ -x "$CODEGEN_BIN.exe" ] && CODEGEN_BIN="$CODEGEN_BIN.exe"
    ;;
esac

SOURCE=""
OUTPUT=""
C_ONLY=0
STDOUT_MODE=0
OPT_LEVEL="2"
CC_CMD="cc"
EXTRA_FLAGS=""
C_TMP=""
EVAL_SCRIPT=""
EVAL_USED=0
EVAL_TMP=""

while [ $# -gt 0 ]; do
  case "$1" in
    --source=*) SOURCE="${1#--source=}" ;;
    --output=*) OUTPUT="${1#--output=}" ;;
    --cc=*)     CC_CMD="${1#--cc=}" ;;
    -o)         shift; OUTPUT="$1" ;;
    -O)         shift; OPT_LEVEL="$1" ;;
    -e)         shift
                if [ "$EVAL_USED" -eq 0 ]; then
                  EVAL_SCRIPT="$1"
                else
                  EVAL_SCRIPT="$EVAL_SCRIPT
$1"
                fi
                EVAL_USED=1 ;;
    -c)         C_ONLY=1 ;;
    -S)         STDOUT_MODE=1 ;;
    *.rb)       [ -z "$SOURCE" ] && SOURCE="$1" ;;
  esac
  shift
done

# `-e` mode: write the accumulated inline script to a temp file and
# treat it as the source. Default output name is `a` since the
# inline form has no .rb basename to derive from. If both -e and a
# .rb file were given, -e wins (consistent with `ruby -e ... script.rb`
# where the .rb file becomes ARGV — Spinel only consumes the source).
if [ "$EVAL_USED" -eq 1 ]; then
  EVAL_TMP="$(mktemp /tmp/spinel_eval.XXXXXX).rb"
  printf '%s\n' "$EVAL_SCRIPT" > "$EVAL_TMP"
  SOURCE="$EVAL_TMP"
fi

if [ -z "$SOURCE" ]; then
  echo "Spinel AOT Compiler" >&2
  echo "" >&2
  echo "Usage: spinel app.rb              - compile to ./app" >&2
  echo "       spinel app.rb -o myapp     - compile to ./myapp" >&2
  echo "       spinel app.rb -c           - generate app.c only" >&2
  echo "       spinel app.rb -S           - print C to stdout" >&2
  echo "       spinel -e 'puts 42'        - compile inline source" >&2
  echo "" >&2
  echo "Options:" >&2
  echo "  -o FILE     Output file" >&2
  echo "  -c          C source only (don't compile)" >&2
  echo "  -S          Print C to stdout" >&2
  echo "  -O LEVEL    Optimization level (default: 2)" >&2
  echo "  --cc=CMD    C compiler (default: cc)" >&2
  echo "  -e STR      Inline Ruby source (repeatable; joined with newlines)" >&2
  exit 1
fi

if [ ! -f "$SOURCE" ]; then
  echo "spinel: $SOURCE: No such file" >&2
  exit 1
fi

if [ "$EVAL_USED" -eq 1 ]; then
  BASENAME="a"
else
  BASENAME="$(basename "$SOURCE" .rb)"
fi
AST_TMP="$(mktemp /tmp/spinel_ast.XXXXXX)"
IR_TMP="$(mktemp /tmp/spinel_ir.XXXXXX)"
trap 'rm -f "$AST_TMP" "$IR_TMP" "$C_TMP" "$EVAL_TMP"' EXIT

# Step 1: Parse. spinel_parse is C-only; build it via `make parse`
# (or `make all`) before invoking spinel.
if [ ! -x "$PARSE_BIN" ]; then
  echo "spinel: parser binary not found at $PARSE_BIN; run 'make parse' or 'make all' first" >&2
  exit 1
fi
"$PARSE_BIN" "$SOURCE" "$AST_TMP"
if [ $? -ne 0 ]; then
  echo "spinel: parse failed" >&2
  exit 1
fi

# Step 2: Analyze (whole-program type inference; emits .ir)
if [ -x "$ANALYZE_BIN" ]; then
  "$ANALYZE_BIN" "$AST_TMP" "$IR_TMP"
else
  ruby "$ANALYZE_RB" "$AST_TMP" "$IR_TMP"
fi
if [ $? -ne 0 ]; then
  echo "spinel: analyze failed" >&2
  exit 1
fi

# Step 3: Codegen
if [ $STDOUT_MODE -eq 1 ]; then
  if [ -x "$CODEGEN_BIN" ]; then
    "$CODEGEN_BIN" "$AST_TMP" "$IR_TMP"
  else
    ruby "$CODEGEN_RB" "$AST_TMP" "$IR_TMP"
  fi
  exit $?
fi

if [ $C_ONLY -eq 1 ]; then
  C_FILE="${OUTPUT:-$BASENAME.c}"
else
  C_TMP="$(mktemp /tmp/spinel_out.XXXXXX.c)"
  C_FILE="$C_TMP"
fi

if [ -x "$CODEGEN_BIN" ]; then
  "$CODEGEN_BIN" "$AST_TMP" "$IR_TMP" "$C_FILE"
else
  ruby "$CODEGEN_RB" "$AST_TMP" "$IR_TMP" "$C_FILE"
fi
if [ $? -ne 0 ]; then
  echo "spinel: codegen failed" >&2
  exit 1
fi

if [ $C_ONLY -eq 1 ]; then
  echo "Wrote $C_FILE" >&2
  exit 0
fi

# Step 3: Compile C -> binary
BIN_FILE="${OUTPUT:-$BASENAME}"
# Runtime library (bigint + regexp)
SP_RT_LIB="$DIR/lib/libspinel_rt.a"
INCLUDE_FLAGS="-I$DIR/lib"
if [ -f "$SP_RT_LIB" ]; then
  EXTRA_FLAGS="$EXTRA_FLAGS $SP_RT_LIB"
fi
# Legacy: optional standalone regexp lib (retained for backward compat)
RE_LIB="$DIR/lib/regexp/libspre.a"
if grep -q 're_compile' "$C_FILE" 2>/dev/null && [ ! -f "$SP_RT_LIB" ] && [ -f "$RE_LIB" ]; then
  EXTRA_FLAGS="$EXTRA_FLAGS $RE_LIB"
fi
INCLUDE_FLAGS="$INCLUDE_FLAGS -I$DIR/lib/regexp"
# Scrape FFI link/cflag markers emitted by the codegen. Each line looks
# like "/* SPINEL_LINK: -lraylib */" or "/* SPINEL_CFLAGS: -I/foo */"
# and comes from an ffi_lib / ffi_cflags declaration.
FFI_LINKS=$(sed -n 's|^/\* SPINEL_LINK: \(.*\) \*/$|\1|p' "$C_FILE" | tr '\n' ' ')
FFI_CFLAGS=$(sed -n 's|^/\* SPINEL_CFLAGS: \(.*\) \*/$|\1|p' "$C_FILE" | tr '\n' ' ')
if [ "$(uname -s)" = "Darwin" ]; then
  GC_FLAG="-Wl,-dead_strip"
else
  GC_FLAG="-Wl,--gc-sections"
fi

# MinGW's default 1MB stack overflows on nontrivial programs; reserve 64MB.
case "$(uname -s 2>/dev/null)" in
  MINGW*|MSYS*|CYGWIN*) EXTRA_FLAGS="$EXTRA_FLAGS -Wl,--stack,67108864" ;;
esac

$CC_CMD -O${OPT_LEVEL} -Wno-all -ffunction-sections -fdata-sections $INCLUDE_FLAGS $FFI_CFLAGS "$C_FILE" -lm $EXTRA_FLAGS $FFI_LINKS $GC_FLAG -o "$BIN_FILE"
if [ $? -ne 0 ]; then
  echo "spinel: C compilation failed" >&2
  exit 1
fi

echo "$SOURCE -> $BIN_FILE" >&2
