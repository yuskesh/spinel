module Outer
  class Thing
    @n: String
    def initialize: (String n) -> void
    def n: () -> String
  end
  module Slots
    @h: Hash[Symbol, untyped]
    def self.set: (Symbol k, untyped v) -> void
    def self.get: (Symbol k) -> String?
  end
  module Use
    def self.label: (Outer::Thing t) -> String
  end
end
